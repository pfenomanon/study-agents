OPENAI_API_KEY=your-openai-key
SUPABASE_URL=https://your-supabase-project.supabase.co
SUPABASE_KEY=your-supabase-service-role-key

# Optional Scenario API overrides. Leave blank to use SUPABASE_URL/SUPABASE_KEY.
SCENARIO_SUPABASE_URL=
SCENARIO_SUPABASE_KEY=

# Optional Ollama cloud/local endpoints
OLLAMA_HOST=
OLLAMA_API_KEY=
OLLAMA_REASON_MODEL=deepseek-v3.1:671b-cloud
REASON_MODEL=gpt-4o

# Optional runtime model overrides
COPILOT_AGENT_MODEL=
COPILOT_AGENT_PROVIDER=
COPILOT_SERVICE_WORKERS=2
SCENARIO_STRUCTURING_PLATFORM=
SCENARIO_STRUCTURING_MODEL=
SCENARIO_STRUCTURING_OLLAMA_TARGET=

# TLS gateway (recommended for remote clients)
PUBLIC_DOMAIN=
ACME_EMAIL=
GATEWAY_ALLOWED_CIDRS=127.0.0.1/32 ::1/128
AUTHELIA_AUTH_USERNAME=gateway-admin
AUTHELIA_AUTH_PASSWORD=
AUTHELIA_POLICY=two_factor
AUTHELIA_DEFAULT_2FA_METHOD=totp
AUTHELIA_SESSION_INACTIVITY=30 minutes
AUTHELIA_SESSION_EXPIRATION=3 hours
AUTHELIA_SESSION_REMEMBER_ME=1 week
AUTHELIA_OIDC_HMAC_SECRET=
AUTHELIA_OIDC_CLIENT_ID=study-agents
AUTHELIA_OIDC_CLIENT_SECRET=
AUTHELIA_OIDC_CLIENT_REDIRECT_URI=
AUTHELIA_SESSION_SECRET=
AUTHELIA_STORAGE_ENCRYPTION_KEY=
AUTHELIA_JWT_SECRET=

# Retrieval/ingestion toggles
USE_HYBRID_RETRIEVAL=true
RAG_USE_DOCLING=true

# API authentication tokens (recommended in production)
API_TOKEN=
RAG_API_TOKEN=
SCENARIO_API_KEY=
COPILOT_API_KEY=
API_REQUIRE_TOKEN=true
RAG_REQUIRE_TOKEN=true
COPILOT_REQUIRE_TOKEN=true
COPILOT_ENABLE_PROFILE_PURGE=false
COPILOT_ENABLE_PROFILE_DELETE=false

# API security controls (optional)
MAX_UPLOAD_BYTES=10485760
DELETE_TEMP_IMAGES=true
API_RATE_LIMIT_PER_MINUTE=120
RAG_RATE_LIMIT_PER_MINUTE=30
SCENARIO_RATE_LIMIT_PER_MINUTE=60
COPILOT_RATE_LIMIT_PER_MINUTE=120
SCENARIO_MAX_BODY_BYTES=524288
COPILOT_MAX_BODY_BYTES=524288
TRUSTED_PROXY_CIDRS=

# Path allowlists (comma-separated absolute paths)
RAG_ALLOWED_INPUT_ROOTS=/app/data
RAG_ALLOWED_OUTPUT_ROOTS=/app/data/output
COPILOT_ALLOWED_FILE_ROOTS=/app/data,/app/research_output

# Scenario API / Copilot UI settings (optional)
SCENARIO_API_CORS=http://localhost:3000
WEB_RESEARCH_ALLOW_PRIVATE_NETWORKS=false
VISION_ALLOW_PRIVATE_REMOTE_URLS=false
