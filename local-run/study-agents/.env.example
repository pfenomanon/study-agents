# -------------------------------
# Required core credentials
# -------------------------------
OPENAI_API_KEY=
SUPABASE_URL=https://your-project.supabase.co
# Use service-role key for backend/API deployments.
SUPABASE_KEY=

# -------------------------------
# Recommended API protection
# If set, clients must send X-API-Key / Bearer token.
# -------------------------------
API_TOKEN=
COPILOT_API_KEY=

# -------------------------------
# Model/runtime settings
# -------------------------------
OPENAI_EMBED_MODEL=text-embedding-3-small
REASON_MODEL=deepseek-v3.1:671b-cloud
REASON_PLATFORM=openai

# Ollama routing (optional)
OLLAMA_HOST=https://ollama.com
OLLAMA_API_KEY=
OLLAMA_TARGET=cloud
OLLAMA_CLOUD_HOST=
OLLAMA_CLOUD_API_KEY=
OLLAMA_LOCAL_HOST=http://127.0.0.1:11434
OLLAMA_LOCAL_API_KEY=

# Web research markdown backend (Docling or Crawl4AI)
WEB_RESEARCH_MARKDOWN_ENGINE=docling
# Option 1: set provider directly (platform/model), e.g. openai/gpt-4o-mini
WEB_RESEARCH_CRAWL4AI_PROVIDER=
# Option 2: set platform + model and let provider be assembled automatically
WEB_RESEARCH_CRAWL4AI_PLATFORM=openai
WEB_RESEARCH_CRAWL4AI_MODEL=gpt-4o-mini
# Token controls for Crawl4AI LLM content filtering
WEB_RESEARCH_CRAWL4AI_API_TOKEN=
WEB_RESEARCH_CRAWL4AI_API_TOKEN_ENV=OPENAI_API_KEY
# Crawl4AI filtering/runtime knobs
WEB_RESEARCH_CRAWL4AI_CHUNK_TOKEN_THRESHOLD=4096
WEB_RESEARCH_CRAWL4AI_IGNORE_LINKS=false
WEB_RESEARCH_CRAWL4AI_HEADLESS=true

# -------------------------------
# Retrieval/ingestion tuning
# -------------------------------
USE_HYBRID_RETRIEVAL=false
RAG_USE_DOCLING=true
SUPABASE_DOCS_TABLE=documents
SUPABASE_NODES_TABLE=kg_nodes
SUPABASE_EDGES_TABLE=kg_edges
SUPABASE_HTTP_TIMEOUT=30
SUPABASE_HTTP_VERIFY=true

# -------------------------------
# API runtime paths and limits
# -------------------------------
MAX_UPLOAD_BYTES=10485760
QA_LOG_DIR=/app/data/qa_sessions
TEMP_IMAGE_DIR=/app/temp_images
PROMPTS_DIR=/app/prompts

# -------------------------------
# Scenario API
# -------------------------------
SCENARIO_API_HOST=0.0.0.0
SCENARIO_API_PORT=9000
SCENARIO_API_CORS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:5173
SCENARIO_API_RELOAD=false
SCENARIO_STORAGE_DIR=/app/data/scenarios
SCENARIO_INGEST_CHUNK_SIZE=900
SCENARIO_INGEST_OVERLAP=120

# Optional Scenario API Supabase overrides.
# Leave blank to reuse SUPABASE_URL/SUPABASE_KEY.
SCENARIO_SUPABASE_URL=
SCENARIO_SUPABASE_KEY=

# -------------------------------
# Local capture defaults
# -------------------------------
TARGET_MONITOR=2
CAPTURE_INTERVAL=5
SCREENSHOT_DIR=data/screenshots
SCHEMA_PDF_PATH=data/pdf/schema_source.pdf
SCHEMA_DEFAULT_CHUNK_SIZE=1200
SCHEMA_DEFAULT_OVERLAP=150
SCHEMA_MODEL_PROVIDER=openai
SCHEMA_MODEL_NAME=gpt-4o-mini

# -------------------------------
# Remote client overrides (optional)
# -------------------------------
REMOTE_API_TOKEN=
REMOTE_MODE=local
REMOTE_CAG_URL=
REMOTE_IMAGE_URL=
REMOTE_MCP_URL=

# -------------------------------
# Vault integration (optional)
# -------------------------------
VAULT_ADDR=
VAULT_TOKEN=
VAULT_DEV_ROOT_TOKEN_ID=root
